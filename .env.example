# Required: Anthropic API key for extraction and scoring
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional
OPENAI_API_KEY=

# Production (Railway + Vercel): set your deployed frontend URL so CORS allows the browser.
# Example: https://agent-readiness-index.vercel.app
FRONTEND_URL=

# Optional: extra allowed origins, comma-separated (e.g. preview deployments)
# ALLOWED_ORIGINS=https://branch-name.vercel.app,https://other.com

# Railway sets PORT automatically — do not set locally unless needed
